# ═══════════════════════════════════════════════════════════
#  BOOTHBOY v2 — Environment Variables
#  วิธีใช้: cp .env.local.example .env.local  แล้วใส่ค่าจริง
# ═══════════════════════════════════════════════════════════

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App URL (ใส่หลัง deploy Vercel)
NEXT_PUBLIC_APP_URL=https://boothboy.vercel.app

# Mac Watcher (.env แยกต่างหาก)
# ALBUM_ID=uuid-ของ-event-จาก-supabase
# NAME_TAGS=ชื่อที่ต้องการ tag
# WATCH_FOLDER=/Users/yourname/Desktop/boothboy-export
